# create a function to fit a model for every individual lion
# (you may have to highlight from "model_df" to "lion_id)" and then run that seperately at first)
fit_model_per_lion <- function(lion_id) {
  model_df <- analysis_df_fs %>% 
    filter(animal_id == lion_id)
  # create a model (m1) that uses the "fit_issf" (integrate step selection) to
  # use the step select analysis for your steps and environmental data
  # (you may have to highlight from "m1" to "= TRUE)" and then run that seperately at first)
  m1 <- fit_issf(model_df, 
                 # Response
                 case_ ~ age_burnsev + vegetation +
                   sl_ + log_sl_ + cos_ta_ +
                   #make sure you include strata!!!
                   strata(step_id_),
                 model = TRUE)
  return(m1)
}

# null issf model for lrt tests per lion
# create a "null" version of the previous model.
# this will be used to compare to the results of the previous model
# to confirm that the results are significant compared to a null model.
# (again, you may have to highlight those parts seperately and then run those first)

fit_model_per_lion_null <- function(lion_id) {
  model_df_null <- analysis_df_fs %>% 
    filter(animal_id == lion_id)
  
  m1_null <- fit_issf(model_df_null, 
                      # Response
                      case_ ~1 +
                        sl_ + log_sl_ + cos_ta_ +
                        strata(step_id_),
                      # Need this later for model predictions
                      model = TRUE)
  return(m1_null)
}

# Run a least Likelihood Ratio Test to compare the original model and the null model
# by using the "anova()" function and a "chisq" test.
anova(m1_null$model, m1$model, test = "Chisq")


