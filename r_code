# Calculate the confidence intervals for the variables/classifications
conf_int_mean_coefs <- mean_coefs %>%
  mutate(
    # 1. Calculate Standard Error
    se = sd.estimate / sqrt(10),
    
    # 2. Get t-critical value for 95% confidence (two-tailed)
    t_crit = qt(0.975, 9),
    
    # 3. Calculate Margin of Error
    margin_error = t_crit * se,
    
    # 4. Calculate Confidence Interval bounds
    lower_ci = mean.estimate - margin_error,
    upper_ci = mean.estimate + margin_error
  )

# combine the "mean_coefs" and the conf_int_mean_coefs" dataframes to plot the confidence intervals
mean_coefs <- cbind(mean_coefs, conf_int_mean_coefs)
