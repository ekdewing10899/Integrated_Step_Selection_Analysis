# data needs to be nested by animal to do resampling. If you click on this "trk_nested",
# each lion is in a single row, and the other corresponding row holds an entire dataframe
# for that lion. This is "nested".
trk_nested <- trk %>% 
  nest(data = -"animal_id")


# Resample the nested tracks (trk_nested). 
# Choose the time between GPS pings. The GPS collars pinged every 2 hours,
# and to catch any that were early/late, I added a 20 minute tolerance.
trk_nested_resampled <- trk_nested  %>%  
  mutate(trks = map(data, function(x) 
    x %>% track_resample(rate = hours(2), tolerance = minutes(20)) %>% steps_by_burst()))  


# Create steps (stp) from the "trk_nested_resampled" dataframe.
# select the fields you want to keep in the steps
# Unnest the tracks (trks)
stp <- trk_nested_resampled %>% 
  select(animal_id, trks) %>% 
  unnest(trks)

