    Y = st_coordinates(.)[,2]
  ) %>%
  st_drop_geometry() %>% 
  select(animal_id, sex, age, datetime_local, X, Y)

# convert to tracks. My points belong in the coordinate system "26910",
# because that is the coordinate system of Northern California.
