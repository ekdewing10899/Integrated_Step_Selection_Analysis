#' puma_fix_rawdat_colnames
#' 
#' mountain lion xlsx and csv data files come in with all sorts of funky column names. this tidies them up
#'
#' @param df 
#'
#' @return
#' @export
#'
#' @examples
puma_fix_colnames <- function(df) {
  names(df) <- str_replace_all(names(df), "Â°", "")
  names(df) <- str_replace_all(names(df), "\\∞", "")
  names(df) <- str_replace_all(names(df), "\\°", "")
  names(df) <- str_replace_all(names(df), "#", "")
  names(df) <- str_replace_all(names(df), "_", ".")
  names(df) <- str_replace_all(names(df), "\\(", "")
  names(df) <- str_replace_all(names(df), "\\)", "")
  names(df) <- str_replace_all(names(df), "\\[", "")
  names(df) <- str_replace_all(names(df), "\\]", "")
  names(df) <- trimws(names(df))
  names(df) <- str_replace_all(names(df), " ", ".")
  names(df) <- tolower(names(df))
  names(df) <- str_replace_all(names(df), "temperature", "temp")
  names(df) <- str_replace_all(names(df), "ecef\\.", "ecef")
  names(df) <- str_replace_all(names(df), "date.gmt", "utc.date")
  names(df) <- str_replace_all(names(df), "time.gmt", "utc.time")
  return(df)
}



