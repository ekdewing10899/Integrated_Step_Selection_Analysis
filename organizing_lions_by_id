lion_collar_summary <- deployments %>% 
  group_by(animal.id, collar.id, collar.start, collar.end) %>%
  summarise(num.row = n(),
            min.date = min(date.local),
            max.date = max(date.local))



lion_collar_summary %>% arrange(animal.id, min.date) %>% view()

 
# finally write the cleaned data frame
write.csv(deployments, here("lion_deployments.csv"), row.names = FALSE)




