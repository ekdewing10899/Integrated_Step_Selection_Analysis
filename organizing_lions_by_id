#' puma_proximity
#' 
#' calculate distance in meters between two mt lions. requires data frame with at least these columns: animal.id, datetime.local, latitude, longitude
#' uses geosphere::distHaversine
#'
#' @param puma1 
#' @param puma2 
#'
#' @return
#' @export
#'
#' @examples
puma_proximity <- function(puma1, puma2) {
df <- deployments %>% 
  select(animal.id, datetime.local, latitude, longitude) %>% 
  mutate(round.datetime = round_date(datetime.local, unit = "1 hour"))

cat1 <- df %>% 
  filter(animal.id == puma1) %>% 
  rename(cat1.id = animal.id,
         cat1.time = datetime.local,
         cat1.lat = latitude,
         cat1.lon = longitude)

cat2 <- df %>% 
  filter(animal.id == puma2) %>% 
  rename(cat2.id = animal.id,
         cat2.time = datetime.local,
         cat2.lat = latitude,
         cat2.lon = longitude)

df_proximity <- right_join(cat1, cat2) %>%
  mutate(
    dist = geosphere::distHaversine(cbind(cat1.lon, cat1.lat), cbind(cat2.lon, cat2.lat))
  )
return(df_proximity)
}

