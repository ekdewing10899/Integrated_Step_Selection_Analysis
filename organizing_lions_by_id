#' puma_mapper
#' 
#' create a simple map showing the path for an individual collared mountain lion. requires all_lions_combined_locations to be loaded in the global environment. currently uses google standard view as the base map.  
#'
#' @param zpuma mountain lion ID
#'
#' @return
#' @export
#'
#' @examples
#' puma_mapper("P1")
puma_mapper <- function(zpuma) {
  zdata <- all_lions_combined_locations %>% 
    filter(puma == zpuma)
  
  first_last <- zdata %>% 
    mutate(first.last = case_when(datetime.local == min(datetime.local) ~ "First GPS fix",
                                  datetime.local == max(datetime.local) ~ "Last GPS fix",
                                  TRUE ~ NA)) %>% 
    filter(!is.na(first.last)) %>% 
    mutate(first.last = paste(first.last, ":", datetime.local))
  
  lon_buffer <- 0.3 * (max(zdata$Longitude) - min(zdata$Longitude))
  lat_buffer <- 0.3 * (max(zdata$Latitude) - min(zdata$Latitude))
  
min_lon = min(zdata$Longitude) - lon_buffer
min_lat = min(zdata$Latitude) - lat_buffer
max_lon = max(zdata$Longitude)+ lon_buffer
max_lat = max(zdata$Latitude)+ lat_buffer
  
  
  zbase_map <- ggmap::get_map(location = c(floor(min_lon), 
                                           floor(min_lat), 
                                           ceiling(max_lon), 
                                           ceiling(max_lat)),
                       source = "google")
  
  ggmap::ggmap(zbase_map) +
    geom_path(data = zdata, aes(x = Longitude, y = Latitude), color = "blue") +
    geom_point(data = first_last, aes(x = Longitude, y = Latitude, color = first.last), size = 3) +
    scale_color_manual(values = c("green", "red")) +
    labs(x = "",
         y = "",
         color = "",
         title = zpuma) + 
    ylim(min_lat, max_lat) +
    xlim(min_lon, max_lon) +
    theme(legend.position="top", 
          legend.direction = "vertical",
          axis.text=element_blank(),
          axis.ticks = element_blank(),
          legend.title=element_blank(),
          plot.margin = unit(c(0, -1, -1, -1), 'lines'))
}



